#!/bin/sh
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
for candidate in \
    "$SCRIPT_DIR/../minecraft/jre25/java-bootstrap" \
    "$SCRIPT_DIR/jre25/java-bootstrap" \
    "$SCRIPT_DIR/minecraft/jre25/java-bootstrap" \
    "$SCRIPT_DIR/../../instances/"*/minecraft/jre25/java-bootstrap; do
    if [ -f "$candidate" ] && [ -x "$candidate" ]; then
        exec "$candidate" "$@"
    fi
done
echo "java-bootstrap: binary not found" >&2
exit 1
